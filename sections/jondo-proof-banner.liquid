<section class="proof-banner">
  <div class="proof-left">
    <p class="proof-award"><span>★</span> {{ section.settings.award_text }}</p>
    <h2 class="proof-h">{{ section.settings.headline }}</h2>
    <p class="proof-sub">{{ section.settings.subheading }}</p>
    <span class="proof-stars">★★★★★</span>
    <blockquote class="proof-quote">{{ section.settings.quote }}</blockquote>
    <span class="proof-attr">— {{ section.settings.quote_attr }}</span>
    <a href="{{ section.settings.btn_link }}" class="proof-btn">{{ section.settings.btn_text }}</a>
  </div>
  <div class="proof-right">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: 'Golfer wearing JONDO Sport sunglasses on the course', width: 1200, height: 924 }}
    {% else %}
      <img src="https://jondosport.com/cdn/shop/files/Image_10-18-25_at_12.21_PM.jpg?crop=region&crop_height=924&crop_left=0&crop_top=232&crop_width=924&v=1760804561&width=1200" alt="Golfer wearing JONDO Sport sunglasses on the course" loading="lazy" width="1200" height="924">
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Proof Banner",
  "tag": "div",
  "class": "jondo-proof-banner-wrap",
  "settings": [
    {
      "type": "text",
      "id": "award_text",
      "label": "Award text",
      "default": "Modrn Golf · 2026"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Voted No. 1 — Best High-End Golf Sunglasses in the USA."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Engineered to Outperform — Golf-Specific Performance Eyewear"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "Very nice and beyond clear. I thought my Maui Jims couldn't be beat. Jondo are the clearest yet!"
    },
    {
      "type": "text",
      "id": "quote_attr",
      "label": "Quote attribution",
      "default": "Will Self, Verified Buyer"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text",
      "default": "Shop Club Champ — $242"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right side image"
    }
  ],
  "presets": [
    {
      "name": "Proof Banner"
    }
  ]
}
{% endschema %}

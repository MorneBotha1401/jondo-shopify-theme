<div class="main-product">
  <div class="main-product-gallery">
    {% if product.featured_image %}
      {{ product.featured_image | image_url: width: 900 | image_tag: alt: product.title, width: 900, height: 900, loading: 'eager' }}
    {% endif %}
  </div>
  <div class="main-product-info">
    <span class="main-product-vendor">{{ product.vendor }}</span>
    <h1 class="main-product-title">{{ product.title }}</h1>
    <p class="main-product-price">{{ product.selected_or_first_available_variant.price | money }}</p>
    {% form 'product', product %}
      <select name="id" class="main-product-variants">
        {% for variant in product.variants %}
          <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>
            {{ variant.title }} — {{ variant.price | money }}
          </option>
        {% endfor %}
      </select>
      <button type="submit" name="add" class="main-product-atc" {% unless product.available %}disabled{% endunless %}>
        {% if product.available %}Add to Cart{% else %}Sold Out{% endif %}
      </button>
    {% endform %}
    <div class="main-product-desc">{{ product.description }}</div>
  </div>
</div>

{% schema %}
{
  "name": "Product",
  "tag": "div",
  "class": "main-product-wrap",
  "settings": [],
  "presets": [{ "name": "Product" }]
}
{% endschema %}

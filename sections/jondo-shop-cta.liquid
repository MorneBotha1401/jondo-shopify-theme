<div class="shop-cta reveal">
  <span class="shop-cta-eyebrow">{{ section.settings.eyebrow }}</span>
  <h2 class="shop-cta-h">{{ section.settings.headline | replace: 'Your lenses', '<em>Your lenses</em>' }}</h2>
  <p class="shop-cta-body">{{ section.settings.body }}</p>
  <a href="{{ section.settings.btn_link }}" class="shop-cta-btn">{{ section.settings.btn_text }}</a>
  <div class="shop-cta-trust">
    <span>{{ section.settings.trust_1 }}</span>
    <span class="shop-cta-trust-sep">·</span>
    <span>{{ section.settings.trust_2 }}</span>
    <span class="shop-cta-trust-sep">·</span>
    <span>{{ section.settings.trust_3 }}</span>
  </div>
</div>

{% schema %}
{
  "name": "Shop CTA",
  "tag": "div",
  "class": "jondo-shop-cta-wrap",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "RX-Lab Cast Golf Eyewear"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Your game is serious. Your lenses should be too."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Every frame. Every lens. One mission — give golfers the clearest, most accurate view of every hole they've ever experienced."
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text",
      "default": "Shop all frames — from $242"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust item 1",
      "default": "30-day returns"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust item 2",
      "default": "Free shipping both ways"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Trust item 3",
      "default": "2-year warranty"
    }
  ],
  "presets": [
    {
      "name": "Shop CTA"
    }
  ]
}
{% endschema %}

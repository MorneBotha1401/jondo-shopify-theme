<section class="email-section">
  <div class="container">
    <span class="email-eyebrow">{{ section.settings.eyebrow }}</span>
    <h2 class="email-h">{{ section.settings.headline | replace: 'your', '<em>your</em>' }}</h2>
    <p class="email-sub">{{ section.settings.subtext }}</p>
    {% if section.settings.klaviyo_form_id != blank %}
      <div class="klaviyo-form-{{ section.settings.klaviyo_form_id }}"></div>
    {% else %}
      <div class="email-form">
        <input type="email" class="email-input" placeholder="Your email address" aria-label="Email address">
        <button class="email-btn">{{ section.settings.btn_text }}</button>
      </div>
    {% endif %}
    <p class="email-trust">{{ section.settings.trust_text }}</p>
  </div>
</section>

<!-- EMAIL SLIDE-IN POPUP -->
<div class="email-slidein" id="email-slidein">
  <button class="email-slidein-close" aria-label="Close">&times;</button>
  <span class="email-slidein-eyebrow">Exclusive Offer</span>
  <div class="email-slidein-h">Get 10% off your first order.</div>
  <p class="email-slidein-sub">Join over 2,400 golfers who see the difference.</p>
  <div class="email-slidein-form">
    <input type="email" class="email-slidein-input" placeholder="Your email address">
    <button class="email-slidein-btn">Claim 10% Off</button>
  </div>
  <p class="email-slidein-trust">{{ section.settings.trust_text }}</p>
</div>

{% schema %}
{
  "name": "Email Capture",
  "tag": "div",
  "class": "jondo-email-capture-wrap",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Join the JONDO Community"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Get 10% off your first order."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Sub text",
      "default": "Plus early access to new frames, Ernie Els content, and exclusive member offers. No spam — just performance."
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text",
      "default": "Claim 10% off"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Trust text",
      "default": "We respect your privacy. Unsubscribe any time."
    },
    {
      "type": "text",
      "id": "klaviyo_form_id",
      "label": "Klaviyo Form ID (optional)",
      "info": "If you have a Klaviyo form, enter the Form ID here and it will replace the default email form.",
      "default": ""
    }
  ],
  "presets": [
    {
      "name": "Email Capture"
    }
  ]
}
{% endschema %}

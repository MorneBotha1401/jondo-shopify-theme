<section class="reviews">
  <div class="section-wm">
    <img src="https://jondosport.com/cdn/shop/files/JondoSport_new_logo_Navy.png?v=1761073533&width=290" alt="" aria-hidden="true" width="290" height="56">
  </div>
  <div class="container" style="position:relative;z-index:1">
    <div class="reviews-head reveal">
      <span class="reviews-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="reviews-h">{{ section.settings.headline | replace: 'for itself.', '<em>for itself.</em>' }}</h2>
      <div class="reviews-rating">
        <span class="reviews-stars">★★★★★</span>
        <span>{{ section.settings.rating }} &nbsp;·&nbsp; {{ section.settings.review_count }} verified reviews</span>
      </div>
    </div>
    <div class="rev-grid">
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
          <div class="rev-card reveal rd{{ forloop.index | modulo: 3 | plus: 1 }}" {{ block.shopify_attributes }}>
            <span class="rev-stars">★★★★★</span>
            <span class="rev-quote-mark">"</span>
            <p class="rev-text">{{ block.settings.text }}</p>
            <span class="rev-product">{{ block.settings.product }}</span>
            <span class="rev-author">{{ block.settings.author }}</span>
          </div>
        {% endif %}
      {% endfor %}
    </div>
    {% if section.settings.cta_link != blank %}
      <div class="reviews-cta reveal">
        <a href="{{ section.settings.cta_link }}" class="btn-outline">{{ section.settings.cta_text }}</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Reviews",
  "tag": "div",
  "class": "jondo-reviews-wrap",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "What Golfers Say"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "The lens speaks for itself."
    },
    {
      "type": "text",
      "id": "rating",
      "label": "Rating",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count",
      "default": "2,400+"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Read all reviews"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": ""
        },
        {
          "type": "text",
          "id": "product",
          "label": "Product name",
          "default": ""
        },
        {
          "type": "text",
          "id": "author",
          "label": "Reviewer name",
          "default": ""
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "text": "As a college golfer I'm always looking for marginal gains. JONDO isn't marginal. It's a completely different level of clarity — from tee-to-green, you can see so many more details.",
            "product": "Club Champ",
            "author": "Hunter Justice — Verified Purchase"
          }
        },
        {
          "type": "review",
          "settings": {
            "text": "After one round I was completely sold. These are without question the clearest sunglasses I have ever worn on a golf course. I can't imagine playing without them now.",
            "product": "Dormie",
            "author": "C. Knight — Verified Buyer"
          }
        },
        {
          "type": "review",
          "settings": {
            "text": "My Maui Jims couldn't be beat — Jondo are the clearest yet. These are the best I have ever experienced and I get to see every little detail. Very nice and beyond clear.",
            "product": "Boetie 2.0",
            "author": "Martin Maritz — Verified Purchase"
          }
        },
        {
          "type": "review",
          "settings": {
            "text": "The JONDO sunglasses are unmatched in their ability to improve your view of the course. Really do make reading greens a lot easier. Worth every single penny.",
            "product": "Fringe",
            "author": "Ruthe Ritterbeck — Verified Purchase"
          }
        },
        {
          "type": "review",
          "settings": {
            "text": "No sunglass haze. I forget I'm wearing them until I take them off. It's like going from standard definition to HD — and staying there for all 18 holes.",
            "product": "Sandy",
            "author": "Edil Angulo — Verified Purchase"
          }
        },
        {
          "type": "review",
          "settings": {
            "text": "Easily the most comfortable pair I've ever worn — and the clarity is in a different league. Love the way they feel and look; impressed with how well they fit and stay on.",
            "product": "Sandy",
            "author": "Stephan Paul — Verified Purchase"
          }
        }
      ]
    }
  ]
}
{% endschema %}

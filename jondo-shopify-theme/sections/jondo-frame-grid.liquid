<section class="frames-section">
  <div class="container">
    <div class="frames-tabs">
      <button class="frames-tab active" data-tab="best">{{ section.settings.tab_1_label }}</button>
      <button class="frames-tab" data-tab="new">{{ section.settings.tab_2_label }}</button>
    </div>

    <!-- Best Sellers -->
    <div class="frames-grid" id="frames-best">
      {% for block in section.blocks %}
        {% if block.settings.tab == 'best' %}
          <a href="{{ block.settings.link }}" class="frame-card" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 800 | image_tag: alt: block.settings.name, loading: 'lazy', width: 800, height: 600 }}
            {% endif %}
            <div class="frame-card-body">
              {% if block.settings.badge != blank %}
                <span class="frame-badge">{{ block.settings.badge }}</span>
              {% endif %}
              <div class="frame-name">{{ block.settings.name }}</div>
              <p class="frame-desc">{{ block.settings.description }}</p>
              <div class="frame-pill-wrap">
                <span class="frame-price">{{ block.settings.price }}</span>
                <span class="frame-pill">{{ block.settings.pill_text }}</span>
              </div>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>

    <!-- New Arrivals -->
    <div class="frames-grid" id="frames-new" hidden>
      {% for block in section.blocks %}
        {% if block.settings.tab == 'new' %}
          <a href="{{ block.settings.link }}" class="frame-card" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 800 | image_tag: alt: block.settings.name, loading: 'lazy', width: 800, height: 600 }}
            {% endif %}
            <div class="frame-card-body">
              {% if block.settings.badge != blank %}
                <span class="frame-badge">{{ block.settings.badge }}</span>
              {% endif %}
              <div class="frame-name">{{ block.settings.name }}</div>
              <p class="frame-desc">{{ block.settings.description }}</p>
              <div class="frame-pill-wrap">
                <span class="frame-price">{{ block.settings.price }}</span>
                <span class="frame-pill">{{ block.settings.pill_text }}</span>
              </div>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>


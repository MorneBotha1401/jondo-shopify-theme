<div class="main-account">
  <h1 class="main-account-title">My Account</h1>
  <p class="main-account-name">{{ customer.name }} &nbsp;·&nbsp; <a href="{{ routes.account_logout_url }}">Log out</a></p>

  <h2 class="main-account-orders-title">Order History</h2>
  {% if customer.orders.size > 0 %}
    <div class="main-account-orders">
      {% for order in customer.orders %}
        <div class="main-account-order">
          <a href="{{ order.customer_url }}" class="main-account-order-num">{{ order.name }}</a>
          <span class="main-account-order-date">{{ order.created_at | date: '%B %d, %Y' }}</span>
          <span class="main-account-order-total">{{ order.total_price | money }}</span>
          <span class="main-account-order-status">{{ order.financial_status_label }}</span>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <p class="main-account-no-orders">You have no orders yet.</p>
  {% endif %}

  <h2 class="main-account-addr-title">Default Address</h2>
  {% if customer.default_address %}
    <address class="main-account-addr">
      {{ customer.default_address | format_address }}
    </address>
  {% endif %}
  <a href="{{ routes.account_addresses_url }}" class="main-account-addr-btn">Manage Addresses</a>
</div>

{% schema %}
{
  "name": "Account",
  "tag": "div",
  "class": "main-account-wrap",
  "settings": [],
  "presets": [{ "name": "Account" }]
}
{% endschema %}

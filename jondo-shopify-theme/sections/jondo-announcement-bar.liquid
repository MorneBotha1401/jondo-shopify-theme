<div class="promo-banner" id="main-content" style="background:{{ section.settings.bg_color }}">
  <div class="promo-inner">
    <span>{{ section.settings.message_1 }}</span>
    <span class="promo-sep">·</span>
    {% if section.settings.message_2_link != blank %}
      <a href="{{ section.settings.message_2_link }}">{{ section.settings.message_2 }}</a>
    {% else %}
      <span>{{ section.settings.message_2 }}</span>
    {% endif %}
    <span class="promo-sep">·</span>
    <span>{{ section.settings.message_3 }}</span>
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "div",
  "class": "jondo-announcement-bar-wrap",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#0C1E3A"
    },
    {
      "type": "text",
      "id": "message_1",
      "label": "Message 1",
      "default": "Free shipping on all US orders"
    },
    {
      "type": "text",
      "id": "message_2",
      "label": "Message 2 (centre link)",
      "default": "Shop the collection"
    },
    {
      "type": "url",
      "id": "message_2_link",
      "label": "Message 2 link"
    },
    {
      "type": "text",
      "id": "message_3",
      "label": "Message 3",
      "default": "30-day returns · 2-year warranty"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}

<section class="vis-diff">
  <div class="vis-diff-panel">
    {% if section.settings.krisp_logo != blank %}
      {{ section.settings.krisp_logo | image_url: width: 500 | image_tag: alt: 'KRISP Extreme', class: 'vis-diff-krisp-logo', width: 500, height: 80 }}
    {% else %}
      <img src="https://jondosport.com/cdn/shop/files/Krisp_Extrem_Transp_Logo.png?v=1759437725&width=500" alt="KRISP Extreme" class="vis-diff-krisp-logo" width="500" height="80">
    {% endif %}
    <h2 class="vis-diff-h">{{ section.settings.headline | replace: 'never before.', '<em>never before.</em>' }}</h2>
    <div class="vis-diff-features">
      <div class="vis-diff-feat">
        <svg class="vis-diff-feat-icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <circle cx="16" cy="16" r="13"/>
          <circle cx="16" cy="16" r="5"/>
          <line x1="16" y1="3" x2="16" y2="8"/>
          <line x1="16" y1="24" x2="16" y2="29"/>
          <line x1="3" y1="16" x2="8" y2="16"/>
          <line x1="24" y1="16" x2="29" y2="16"/>
        </svg>
        <span class="vis-diff-feat-label">{{ section.settings.feature_1_text }}</span>
      </div>
      <div class="vis-diff-feat">
        <svg class="vis-diff-feat-icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <path d="M3 16s5-9 13-9 13 9 13 9-5 9-13 9S3 16 3 16z"/>
          <circle cx="16" cy="16" r="4"/>
        </svg>
        <span class="vis-diff-feat-label">{{ section.settings.feature_2_text }}</span>
      </div>
    </div>
    <a href="{{ section.settings.cta_link }}" class="vis-diff-cta">{{ section.settings.cta_text }}</a>
  </div>
  <div class="vis-diff-photo">
    {% if section.settings.lens_image != blank %}
      {{ section.settings.lens_image | image_url: width: 1200 | image_tag: alt: 'Golf course viewed through KRISP Extreme lens', class: 'lens-krisp', id: 'lens-img', width: 1200, height: 800 }}
    {% else %}
      <div id="lens-img" class="lens-krisp"></div>
    {% endif %}
    <span class="lens-label" id="lens-label">{{ section.settings.btn_3_label }}</span>
    <div class="lens-btns">
      <button class="lens-btn" data-lens="budget" data-label="{{ section.settings.btn_1_label }}">{{ section.settings.btn_1_label }}</button>
      <button class="lens-btn" data-lens="premium" data-label="{{ section.settings.btn_2_label }}">{{ section.settings.btn_2_label }}</button>
      <button class="lens-btn active" data-lens="krisp" data-label="{{ section.settings.btn_3_label }}">{{ section.settings.btn_3_label }}</button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Visual Difference",
  "tag": "div",
  "class": "jondo-visual-difference-wrap",
  "settings": [
    {
      "type": "image_picker",
      "id": "krisp_logo",
      "label": "KRISP Extreme logo",
      "info": "Upload Krisp_Extrem_Transp_Logo.png to Shopify Files then select it here."
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Experience golf like never before."
    },
    {
      "type": "text",
      "id": "feature_1_text",
      "label": "Feature 1 text",
      "default": "Golf-Specific Lens Technology"
    },
    {
      "type": "text",
      "id": "feature_2_text",
      "label": "Feature 2 text",
      "default": "World-Class Optical Clarity"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Shop KRISP Extreme — From $242"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    },
    {
      "type": "image_picker",
      "id": "lens_image",
      "label": "Lens comparison image",
      "info": "Upload golf-lens.jpg to Shopify Files then select it here."
    },
    {
      "type": "text",
      "id": "btn_1_label",
      "label": "Lens button 1 label",
      "default": "Budget Lens"
    },
    {
      "type": "text",
      "id": "btn_2_label",
      "label": "Lens button 2 label",
      "default": "Premium Brand"
    },
    {
      "type": "text",
      "id": "btn_3_label",
      "label": "Lens button 3 label",
      "default": "KRISP Extreme"
    }
  ],
  "presets": [
    {
      "name": "Visual Difference"
    }
  ]
}
{% endschema %}

<footer>
  <div class="footer-main">
    <div class="footer-grid">
      <div>
        {% if section.settings.logo != blank %}
          {{ section.settings.logo | image_url: width: 290 | image_tag: alt: shop.name, class: 'footer-brand-logo', width: 290, height: 56 }}
        {% else %}
          <img class="footer-brand-logo" src="https://jondosport.com/cdn/shop/files/JondoSport_new_logo_Navy.png?v=1761073533&width=290" alt="{{ shop.name }}" width="290" height="56">
        {% endif %}
        <span class="footer-tagline">{{ section.settings.tagline }}</span>
        <p class="footer-mission">{{ section.settings.mission }}</p>
        <div class="footer-trust">
          {% if section.settings.trust_1 != blank %}<span class="footer-trust-item">{{ section.settings.trust_1 }}</span>{% endif %}
          {% if section.settings.trust_2 != blank %}<span class="footer-trust-item">{{ section.settings.trust_2 }}</span>{% endif %}
          {% if section.settings.trust_3 != blank %}<span class="footer-trust-item">{{ section.settings.trust_3 }}</span>{% endif %}
        </div>
        <span class="footer-nl-label">Sign up for exclusive offers</span>
        <div class="footer-nl-form">
          <input type="email" class="footer-nl-input" placeholder="Your email address">
          <button class="footer-nl-btn">Subscribe</button>
        </div>
      </div>

      {% for block in section.blocks %}
        {% if block.type == 'footer_column' %}
          <div {{ block.shopify_attributes }}>
            <span class="footer-col-h">{{ block.settings.heading }}</span>
            <ul class="footer-col-links">
              {% assign link_lines = block.settings.links | newline_to_br | split: '<br />' %}
              {% for line in link_lines %}
                {% assign line_trimmed = line | strip %}
                {% if line_trimmed != blank %}
                  {% assign parts = line_trimmed | split: '|' %}
                  {% if parts.size >= 2 %}
                    <li><a href="{{ parts[1] | strip }}">{{ parts[0] | strip }}</a></li>
                  {% else %}
                    <li><a href="#">{{ line_trimmed }}</a></li>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">{{ section.settings.copyright }}</span>
      <div class="footer-social">
        {% if section.settings.instagram_url != blank %}
          <a href="{{ section.settings.instagram_url }}">Instagram</a>
        {% endif %}
        {% if section.settings.facebook_url != blank %}
          <a href="{{ section.settings.facebook_url }}">Facebook</a>
        {% endif %}
        {% if section.settings.tiktok_url != blank %}
          <a href="{{ section.settings.tiktok_url }}">TikTok</a>
        {% endif %}
      </div>
      <div class="footer-payments">
        <span class="pay-badge">Visa</span>
        <span class="pay-badge">Mastercard</span>
        <span class="pay-badge">Amex</span>
        <span class="pay-badge">PayPal</span>
        <span class="pay-badge">Shop Pay</span>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "div",
  "class": "jondo-footer-wrap",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "The lens is the difference."
    },
    {
      "type": "textarea",
      "id": "mission",
      "label": "Mission statement",
      "default": "Premium golf eyewear engineered for those who refuse to compromise. KRISP Extreme RX-lab cast technology — built in partnership with 4× Major Champion Ernie Els."
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust item 1",
      "default": "Patented lens technology"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust item 2",
      "default": "Co-Founded by Ernie Els"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Trust item 3",
      "default": "2-Year Warranty"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "default": "© 2026 JONDO Sport. All rights reserved."
    },
    {
      "type": "header",
      "content": "Social Links"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    }
  ],
  "blocks": [
    {
      "type": "footer_column",
      "name": "Footer Column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading",
          "default": "Links"
        },
        {
          "type": "textarea",
          "id": "links",
          "label": "Links",
          "info": "One link per line in format: Label | URL (e.g. All Frames | /collections/all)",
          "default": ""
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "footer_column",
          "settings": {
            "heading": "Shop",
            "links": "All Frames | https://www.jondosport.com/collections/golf-sunglasses\nSmall / Medium | https://www.jondosport.com/collections/golf-sunglasses\nMedium / Large | https://www.jondosport.com/collections/golf-sunglasses\nWomen's | https://www.jondosport.com/collections/golf-sunglasses"
          }
        },
        {
          "type": "footer_column",
          "settings": {
            "heading": "Learn",
            "links": "The Krisp Difference | https://www.jondosport.com/pages/krisp-extreme-explained\nWhy Buy JONDO | https://www.jondosport.com/pages/why-buy-jondo\nJournal | https://www.jondosport.com/blogs/news"
          }
        },
        {
          "type": "footer_column",
          "settings": {
            "heading": "Support",
            "links": "FAQs | https://www.jondosport.com/pages/jondo-faq\nContact Us | mailto:info@jondosport.com\nShipping Policy | https://www.jondosport.com/policies/shipping-policy\nReturns | https://www.jondosport.com/policies/refund-policy"
          }
        }
      ]
    }
  ]
}
{% endschema %}

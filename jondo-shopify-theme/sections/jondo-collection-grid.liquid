<section class="coll2-wrap">
  <div class="coll2-wrap-header reveal">
    <span class="coll2-wrap-eyebrow">{{ section.settings.eyebrow }}</span>
    <div class="coll2-wrap-h">{{ section.settings.headline | replace: 'find your frame.', '<em>find your frame.</em>' }}</div>
    <a href="{{ section.settings.btn_link }}" class="coll2-wrap-btn">{{ section.settings.btn_text }}</a>
  </div>
  <div class="coll2">
    {% for block in section.blocks %}
      {% if block.type == 'photo_tile' %}
        <a href="{{ block.settings.link }}" class="coll2-tile" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 1200 | image_tag: alt: block.settings.headline, loading: 'lazy', width: 1200, height: 800 }}
          {% endif %}
          <div class="coll2-tile-content">
            <span class="coll2-tile-eyebrow">{{ block.settings.eyebrow }}</span>
            <div class="coll2-tile-h">{{ block.settings.headline }}</div>
            <span class="coll2-tile-link">{{ block.settings.link_text }}</span>
          </div>
        </a>
      {% elsif block.type == 'text_tile' %}
        <div class="coll2-typo"{% if block.settings.dark_bg %} style="background:var(--bg-darker)"{% endif %} {{ block.shopify_attributes }}>
          <span class="coll2-typo-bg-num">{{ forloop.index }}.</span>
          <span class="coll2-typo-eyebrow">{{ block.settings.eyebrow }}</span>
          <h3 class="coll2-typo-h">{{ block.settings.headline }}</h3>
          <p class="coll2-typo-body">{{ block.settings.body }}</p>
          <a href="{{ block.settings.link }}" class="coll2-typo-link">{{ block.settings.link_text }}</a>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
